# ─────────────────────────────────────────────
# Flow IT — Backend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
PORT=3000
CORS_ORIGINS=http://localhost:5173

# Security (generate strong random secrets for production)
JWT_SECRET=change_this_to_a_long_random_secret_before_production
SESSION_SECRET=change_this_session_secret_before_production
SEED_SECRET=change_this_seed_secret

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flowit"

# App identity (white-label — change per deployment)
APP_NAME=Flow IT
APP_VERSION=1.0.0
APP_URL=https://yourdomain.com

# Email / SMTP (required for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=no-reply@yourapp.com

# Initial super admin (used by seed script)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_EMAIL_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
ADMIN_LAST_NAME=User

# AI integration (optional)
OPENROUTER_API_KEY=

# File storage (optional — Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# FLOW IT — Backend environment variables (.env.example)
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. In Vercel: Settings → Environment Variables (add the same keys)
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────────────────
# Generate strong random values: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_before_production
SESSION_SECRET=change_this_session_secret_before_production
SEED_SECRET=change_this_seed_secret

# ── Database ──────────────────────────────────────────────────────────────────
# Standard Postgres (local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/flowit"

# Prisma Accelerate (production — get from console.prisma.io)
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY"

# ── App identity (white-label) ────────────────────────────────────────────────
APP_NAME=Flow IT
APP_VERSION=1.0.0
APP_URL=http://localhost:5173

# ── Email / SMTP (required for password reset) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# For Gmail: use an App Password (myaccount.google.com → Security → App passwords)
SMTP_PASS=your-app-password
SMTP_FROM=no-reply@yourapp.com

# ── Initial super-admin (used by `npm run seed`) ──────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_EMAIL_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
ADMIN_LAST_NAME=User

# ── AI integration (optional) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
